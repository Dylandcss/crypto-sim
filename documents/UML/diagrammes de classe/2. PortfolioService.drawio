        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam defaultFontName \&quot;Consolas\&quot;\nskinparam fontSize 12\n\npackage \&quot;PortfolioService\&quot; {\n\n  package \&quot;Models\&quot; {\n    class Holding {\n      + Id : int\n      + UserId : int\n      + CryptoSymbol : string\n      + Quantity : decimal\n      + AverageBuyPrice : decimal\n      + UpdatedAt : DateTime\n    }\n\n    class Transaction {\n      + Id : int\n      + HoldingId : int\n      + UserId : int\n      + CryptoSymbol : string\n      + Type : OrderType\n      + Quantity : decimal\n      + PriceAtTime : decimal\n      + Total : decimal\n      + ExecutedAt : DateTime\n    }\n  }\n\n  package \&quot;Enums\&quot; {\n    enum OrderType {\n      Buy\n      Sell\n    }\n  }\n\n  package \&quot;DTOs\&quot; {\n    class HoldingDetail &lt;&lt;DTO&gt;&gt; {\n      + Symbol : string\n      + Quantity : decimal\n      + CurrentPrice : decimal\n      + GainLoss : decimal\n    }\n\n    class PortfolioSummary &lt;&lt;DTO&gt;&gt; {\n      + CashBalance : decimal\n      + TotalCurrentValue : decimal\n      + TotalGainLoss : decimal\n      + Holdings : List&lt;HoldingDetail&gt;\n    }\n  }\n\n  &#39; Relations\n  Holding \&quot;1\&quot; *-- \&quot;*\&quot; Transaction : \&quot;contient\&quot;\n  Transaction --&gt; OrderType : \&quot;utilise\&quot;\n\n}\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="011rBhh1KeOwGc_0GFQw-164">
