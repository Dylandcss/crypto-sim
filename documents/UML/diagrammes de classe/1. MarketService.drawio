        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam defaultFontName \&quot;Consolas\&quot;\nskinparam fontSize 12\n\npackage \&quot;MarketService\&quot; {\n\n  package \&quot;Models\&quot; {\n    class Crypto {\n      + Id : int\n      + Symbol : string\n      + Name : string\n      + CurrentPrice : decimal\n      + LastUpdated : DateTime\n      --\n      + History : List&lt;PriceHistory&gt;\n    }\n\n    class PriceHistory {\n      + Id : int\n      + CryptoId : int\n      + Price : decimal\n      + RecordedAt : DateTime\n      --\n      + Crypto : Crypto\n    }\n  }\n\n  package \&quot;DTOs\&quot; {\n    class CryptoResponse &lt;&lt;DTO&gt;&gt; {\n      + Symbol : string\n      + Name : string\n      + CurrentPrice : decimal\n      + DailyChangePercent : decimal\n    }\n\n    class PriceUpdateDto &lt;&lt;SignalR&gt;&gt; {\n      + Symbol : string\n      + NewPrice : decimal\n      + Timestamp : DateTime\n    }\n\n    class HistoryResponse &lt;&lt;DTO&gt;&gt; {\n      + Symbol : string\n      + DataPoints : List&lt;PricePoint&gt;\n    }\n  }\n\n  package \&quot;Services (Logique)\&quot; {\n    class PriceSimulatorService &lt;&lt;BackgroundService&gt;&gt; {\n      + ExecuteAsync() : Task\n      - UpdatePrices() : void\n    }\n\n    class MarketHub &lt;&lt;SignalR Hub&gt;&gt; {\n      + SendPriceUpdate(List&lt;PriceUpdateDto&gt;) : Task\n    }\n  }\n\n  &#39; Relations\n  Crypto \&quot;1\&quot; *-- \&quot;*\&quot; PriceHistory : Possède\n  PriceSimulatorService ..&gt; MarketHub : \&quot;Utilise pour diffuser\&quot;\n  PriceSimulatorService ..&gt; Crypto : \&quot;Met à jour\&quot;\n\n}\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="011rBhh1KeOwGc_0GFQw-164">
