        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam defaultFontName \&quot;Consolas\&quot;\nskinparam fontSize 12\n\npackage \&quot;OrderService\&quot; {\n\n  package \&quot;Models\&quot; {\n    class Order {\n      + Id : int\n      + UserId : int\n      + CryptoSymbol : string\n      + Type : OrderType\n      + Quantity : decimal\n      + Price : decimal\n      + Total : decimal\n      + Status : OrderStatus\n      + CreatedAt : DateTime\n      + ExecutedAt : DateTime?\n    }\n  }\n\n  package \&quot;Enums\&quot; {\n    enum OrderType {\n      Buy\n      Sell\n    }\n\n    enum OrderStatus {\n      Pending\n      Executed\n      Cancelled\n      Rejected\n    }\n  }\n\n  package \&quot;DTOs\&quot; {\n    class OrderRequest &lt;&lt;DTO&gt;&gt; {\n      + CryptoSymbol : string\n      + Type : OrderType\n      + Quantity : decimal\n    }\n\n    class OrderResponse &lt;&lt;DTO&gt;&gt; {\n      + OrderId : int\n      + Status : OrderStatus\n      + ExecutedAt : DateTime?\n      + ErrorMessage : string\n    }\n  }\n\n  Order --&gt; OrderType : \&quot;définit\&quot;\n  Order --&gt; OrderStatus : \&quot;suit\&quot;\n}\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="011rBhh1KeOwGc_0GFQw-164">
