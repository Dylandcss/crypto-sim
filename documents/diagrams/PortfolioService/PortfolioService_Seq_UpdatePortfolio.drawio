    <mxCell id="m5_self_buy" value="if holding == null:&#xa;  new Holding {qty=dto.Qty, avgBuyPrice=dto.Price}&#xa;  -> AddHoldingAsync(holding)&#xa;else:&#xa;  avgPrice = (h.Qty*h.avgBuyPrice + dto.Qty*dto.Price) / (h.Qty+dto.Qty)&#xa;  holding.Quantity += dto.Qty&#xa;  holding.AverageBuyPrice = avgPrice&#xa;  -> UpdateHoldingAsync(holding)" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;html=1;endArrow=open;endFill=0;fontSize=10;" edge="1" parent="1">
