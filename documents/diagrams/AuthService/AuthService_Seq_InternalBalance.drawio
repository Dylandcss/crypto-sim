    <!-- ═══════════════════════════ -->
    <!--         MESSAGES           -->
    <!-- ═══════════════════════════ -->

    <!-- 1. OrderService → AuthController -->
    <mxCell id="m1" value="PUT /api/auth/internal/balance/{userId}  [X-Internal-Key: &lt;key&gt;]  {amount}" style="edgeStyle=none;endArrow=block;endFill=1;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="100" y="180" as="sourcePoint"/><mxPoint x="330" y="180" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- 2. AuthController : self-loop validation clé interne -->
    <mxCell id="m2_self" value="IsInternalRequest()&#xa;Headers[X-Internal-Key] == config[INTERNAL_API_KEY]" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;html=1;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="330" y="220" as="sourcePoint"/>
        <mxPoint x="330" y="275" as="targetPoint"/>
        <Array as="points"><mxPoint x="430" y="220"/><mxPoint x="430" y="275"/></Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2_label" value="[true → autorisé]" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="435" y="232" width="150" height="20" as="geometry"/>
    </mxCell>

    <!-- 3. AuthController → AuthManagementService -->
    <mxCell id="m3" value="UpdateBalanceAsync(userId, amount)" style="edgeStyle=none;endArrow=block;endFill=1;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="330" y="310" as="sourcePoint"/><mxPoint x="580" y="310" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- 4. AuthManagementService → AuthRepository -->
    <mxCell id="m4" value="UpdateUserBalanceAsync(userId, amount)" style="edgeStyle=none;endArrow=block;endFill=1;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="580" y="355" as="sourcePoint"/><mxPoint x="820" y="355" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- 5. AuthRepository → AuthDbContext : FindAsync -->
    <mxCell id="m5" value="FindAsync(userId)" style="edgeStyle=none;endArrow=block;endFill=1;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="820" y="395" as="sourcePoint"/><mxPoint x="1050" y="395" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- 6. AuthDbContext → AuthRepository : user -->
    <mxCell id="m6" value="User (entity)" style="edgeStyle=none;dashed=1;endArrow=open;endFill=0;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="1050" y="430" as="sourcePoint"/><mxPoint x="820" y="430" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- 7. AuthRepository : modifie balance + SaveChangesAsync -->
    <mxCell id="m7_self" value="user.Balance += amount&#xa;SaveChangesAsync()" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;html=1;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
