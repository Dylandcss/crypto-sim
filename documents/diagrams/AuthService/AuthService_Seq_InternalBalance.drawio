        <Array as="points"><mxPoint x="920" y="470"/><mxPoint x="920" y="525"/></Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m7_note" value="via AuthDbContext" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="925" y="482" width="130" height="20" as="geometry"/>
    </mxCell>

    <!-- 8. AuthRepository → AuthManagementService : true -->
    <mxCell id="m8" value="true  (succès)" style="edgeStyle=none;dashed=1;endArrow=open;endFill=0;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
