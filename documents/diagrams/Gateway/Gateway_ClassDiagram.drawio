    <mxCell id="prog_content" value="builder.Services.AddHttpClient('AuthClient', c => c.BaseAddress = AUTH_SERVICE_URL)&#xa;builder.Services.AddHttpClient('MarketClient', ...)&#xa;builder.Services.AddHttpClient('PortfolioClient', ...)&#xa;builder.Services.AddHttpClient('OrderClient', ...)&#xa;builder.Services.AddAuthentication(JwtBearer) { HMAC-SHA256, issuer, audience, key }&#xa;builder.Services.AddReverseProxy().LoadFromConfig(yarp_config)&#xa;builder.Services.AddCors(AllowAnyOrigin/Method/Header)&#xa;&#xa;Pipeline: UseCors -> UseAuthentication -> UseAuthorization -> MapControllers -> MapReverseProxy" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;verticalAlign=top;" vertex="1" parent="program">
