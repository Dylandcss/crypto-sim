    <mxCell id="m13_self" value="Task.Delay(MARKET_UPDATE_INTERVAL, stoppingToken)" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;html=1;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1">
