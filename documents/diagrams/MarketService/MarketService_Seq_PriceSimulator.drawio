    <!-- 5. DB -> Repo -->
    <mxCell id="m5" value="List&lt;Crypto&gt;" style="edgeStyle=none;dashed=1;endArrow=open;endFill=0;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="692" y="390" as="sourcePoint"/><mxPoint x="482" y="390" as="targetPoint"/></mxGeometry>
