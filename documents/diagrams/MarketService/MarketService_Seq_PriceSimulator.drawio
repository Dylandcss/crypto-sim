    <!-- 6. Repo -> Sim -->
    <mxCell id="m6" value="List&lt;Crypto&gt;" style="edgeStyle=none;dashed=1;endArrow=open;endFill=0;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="482" y="420" as="sourcePoint"/><mxPoint x="280" y="420" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- 7. foreach crypto - apply random variation -->
    <mxCell id="m7_self" value="foreach crypto:&#xa;  variation = Random +/- 2%&#xa;  crypto.CurrentPrice *= (1 + variation)&#xa;  crypto.LastUpdated = DateTime.UtcNow" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;html=1;endArrow=open;endFill=0;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="280" y="455" as="sourcePoint"/>
        <mxPoint x="280" y="535" as="targetPoint"/>
        <Array as="points"><mxPoint x="370" y="455"/><mxPoint x="370" y="535"/></Array>
      </mxGeometry>
    </mxCell>

    <!-- 8. UpdateCryptoAsync -->
    <mxCell id="m8" value="UpdateCryptoAsync(crypto)" style="edgeStyle=none;endArrow=block;endFill=1;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="280" y="565" as="sourcePoint"/><mxPoint x="482" y="565" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- 9. Repo -> DB SaveChanges -->
    <mxCell id="m9" value="Entry(crypto).State = Modified; SaveChangesAsync()" style="edgeStyle=none;endArrow=block;endFill=1;html=1;fontSize=10;verticalAlign=bottom;" edge="1" parent="1">
