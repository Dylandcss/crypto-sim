      <mxGeometry x="175" y="230" width="1160" height="570" as="geometry"/>
    </mxCell>

    <!-- 2. SimulateAsync self-call -->
    <mxCell id="m2" value="SimulateAsync()" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;html=1;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="280" y="255" as="sourcePoint"/>
        <mxPoint x="280" y="295" as="targetPoint"/>
        <Array as="points"><mxPoint x="355" y="255"/><mxPoint x="355" y="295"/></Array>
