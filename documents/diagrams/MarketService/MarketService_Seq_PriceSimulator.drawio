    <mxCell id="m10" value="AddHistoryEntryAsync(new PriceHistory {Symbol, Price, DateTime.UtcNow})" style="edgeStyle=none;endArrow=block;endFill=1;html=1;fontSize=10;verticalAlign=bottom;" edge="1" parent="1">
