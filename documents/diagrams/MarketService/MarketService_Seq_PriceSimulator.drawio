    <!-- 4. Repo -> DB -->
    <mxCell id="m4" value="Cryptos.ToListAsync()" style="edgeStyle=none;endArrow=block;endFill=1;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="482" y="360" as="sourcePoint"/><mxPoint x="692" y="360" as="targetPoint"/></mxGeometry>
