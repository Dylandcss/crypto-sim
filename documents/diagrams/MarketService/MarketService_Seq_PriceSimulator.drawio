    <!-- 1. Host starts background service -->
    <mxCell id="m1" value="StartAsync() / ExecuteAsync(stoppingToken)" style="edgeStyle=none;endArrow=block;endFill=1;html=1;fontSize=11;verticalAlign=bottom;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="90" y="180" as="sourcePoint"/><mxPoint x="280" y="180" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- LOOP box -->
    <mxCell id="loop_box" value="loop [!stoppingToken.IsCancellationRequested]" style="text;html=1;strokeColor=#b85450;fillColor=#fff2cc;align=left;fontSize=11;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
