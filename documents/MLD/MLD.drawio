        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam defaultFontName \&quot;Consolas\&quot;\nskinparam fontSize 11\nskinparam entity {\n    BackgroundColor white\n    BorderColor black\n}\n\npackage \&quot;AuthService (users_db)\&quot; {\n  entity \&quot;Users\&quot; {\n    &lt;color:blue&gt;&lt;b&gt;#Id&lt;/b&gt;&lt;/color&gt; : INT &lt;&lt;PK&gt;&gt;\n    --\n    Username : VARCHAR(50) &lt;&lt;UNIQUE&gt;&gt;\n    PasswordHash : TEXT\n    Email : VARCHAR(255) &lt;&lt;UNIQUE&gt;&gt;\n    Role : VARCHAR(20)\n    Balance : DECIMAL(18,8)\n    CreatedAt : DATETIME\n  }\n}\n\npackage \&quot;MarketService (market_db)\&quot; {\n  entity \&quot;Cryptos\&quot; {\n    &lt;color:blue&gt;&lt;b&gt;#Id&lt;/b&gt;&lt;/color&gt; : INT &lt;&lt;PK&gt;&gt;\n    --\n    Symbol : VARCHAR(10) &lt;&lt;UNIQUE&gt;&gt;\n    Name : VARCHAR(100)\n    CurrentPrice : DECIMAL(18,8)\n    LastUpdated : DATETIME\n  }\n  \n  entity \&quot;PriceHistory\&quot; {\n    &lt;color:blue&gt;&lt;b&gt;#Id&lt;/b&gt;&lt;/color&gt; : INT &lt;&lt;PK&gt;&gt;\n    --\n    &lt;color:green&gt;&lt;b&gt;CryptoId&lt;/b&gt;&lt;/color&gt; : INT &lt;&lt;FK&gt;&gt;\n    Price : DECIMAL(18,8)\n    RecordedAt : DATETIME\n  }\n  \n  Cryptos ||--o{ PriceHistory : \&quot;1:N\&quot;\n}\n\npackage \&quot;PortfolioService (portfolio_db)\&quot; {\n  entity \&quot;Holdings\&quot; {\n    &lt;color:blue&gt;&lt;b&gt;#Id&lt;/b&gt;&lt;/color&gt; : INT &lt;&lt;PK&gt;&gt;\n    --\n    UserId : INT\n    CryptoSymbol : VARCHAR(10)\n    Quantity : DECIMAL(18,8)\n    AverageBuyPrice : DECIMAL(18,8)\n    UpdatedAt : DATETIME\n  }\n  \n  entity \&quot;Transactions\&quot; {\n    &lt;color:blue&gt;&lt;b&gt;#Id&lt;/b&gt;&lt;/color&gt; : INT &lt;&lt;PK&gt;&gt;\n    --\n    &lt;color:green&gt;&lt;b&gt;HoldingId&lt;/b&gt;&lt;/color&gt; : INT &lt;&lt;FK&gt;&gt;\n    UserId : INT\n    CryptoSymbol : VARCHAR(10)\n    Type : VARCHAR(10)\n    Quantity : DECIMAL(18,8)\n    PriceAtTime : DECIMAL(18,8)\n    Total : DECIMAL(18,8)\n    ExecutedAt : DATETIME\n  }\n  \n  Holdings ||--o{ Transactions : \&quot;1:N\&quot;\n}\n\npackage \&quot;OrderService (orders_db)\&quot; {\n  entity \&quot;Orders\&quot; {\n    &lt;color:blue&gt;&lt;b&gt;#Id&lt;/b&gt;&lt;/color&gt; : INT &lt;&lt;PK&gt;&gt;\n    --\n    UserId : INT\n    CryptoSymbol : VARCHAR(10)\n    Type : VARCHAR(10)\n    Quantity : DECIMAL(18,8)\n    Price : DECIMAL(18,8)\n    Total : DECIMAL(18,8)\n    Status : VARCHAR(20)\n    CreatedAt : DATETIME\n    ExecutedAt : DATETIME\n  }\n}\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="011rBhh1KeOwGc_0GFQw-163">
